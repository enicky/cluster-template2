---
apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: envoy-gateway
  namespace: argo-system
  annotations:
    argocd.argoproj.io/sync-wave: '0'
spec:
  project: kubernetes
  sources:
    - repoURL: mirror.gcr.io/envoyproxy
      chart: gateway-helm
      targetRevision: v1.6.0
      helm:
        releaseName: envoy-gateway
    - repoURL: "https://github.com/#{ repository_name }#.git"
      path: kubernetes/apps/network/envoy-gateway
      targetRevision: #{ repository_branch }#
      ref: repo
  destination:
    name: in-cluster
    namespace: network
  ignoreDifferences:
    - kind: CustomResourceDefinition
      jqPathExpressions:
        - '.metadata.annotations."controller-gen.kubebuilder.io/version"'
    - kind: ConfigMap
      name: envoy-gateway-config
      namespace: network
      jsonPointers:
        - /metadata/labels
        - /metadata/annotations
        - /metadata/managedFields
  syncPolicy:
    automated:
      allowEmpty: true
      prune: true
      selfHeal: true
    retry:
      limit: 1
      backoff:
        duration: 10s
        factor: 2
        maxDuration: 3m
    syncOptions:
      - CreateNamespace=true
      - ApplyOutOfSyncOnly=true
      - ServerSideApply=true
      - PruneLast=true
      - RespectIgnoreDifferences=true
      - ForceApply=true
