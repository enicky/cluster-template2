apiVersion: v1
kind: Service
metadata:
  name: envoy-external
  namespace: network
spec:
  type: ClusterIP
  selector:
    gateway.envoyproxy.io/owning-gateway-name: envoy-external
  ports:
  - name: http
    port: 80
    protocol: TCP
    targetPort: 10080
  - name: https
    port: 443
    protocol: TCP
    targetPort: 10443
