---
apiVersion: v1
kind: Service
metadata:
  name: healthtracking-postgres
  namespace: home
spec:
  clusterIP: None
  selector:
    app.kubernetes.io/name: healthtracking-postgres
  ports:
    - port: 5432
      protocol: TCP
      targetPort: 5432
---
apiVersion: apps/v1
kind: StatefulSet
metadata:
  name: healthtracking-postgres
  namespace: home
spec:
  serviceName: healthtracking-postgres
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: healthtracking-postgres
  template:
    metadata:
      labels:
        app.kubernetes.io/name: healthtracking-postgres
    spec:
      securityContext:
        fsGroup: 999
        fsGroupChangePolicy: OnRootMismatch
      containers:
        - name: postgres
          image: postgres:16-alpine
          imagePullPolicy: IfNotPresent
          ports:
            - name: postgres
              containerPort: 5432
              protocol: TCP
          env:
            - name: POSTGRES_DB
              value: #{ bootstrap_apps.healthtracking.database.name }#
            - name: POSTGRES_USER
              value: #{ bootstrap_apps.healthtracking.database.user }#
            - name: POSTGRES_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: healthtracking-db
                  key: DB_PASSWORD
          livenessProbe:
            exec:
              command:
                - /bin/sh
                - -c
                - pg_isready -U #{ bootstrap_apps.healthtracking.database.user }#
            initialDelaySeconds: 30
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            exec:
              command:
                - /bin/sh
                - -c
                - pg_isready -U #{ bootstrap_apps.healthtracking.database.user }#
            initialDelaySeconds: 10
            periodSeconds: 5
            timeoutSeconds: 3
            failureThreshold: 3
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              cpu: 500m
              memory: 512Mi
          securityContext:
            allowPrivilegeEscalation: false
            capabilities:
              drop: ["ALL"]
          volumeMounts:
            - name: data
              mountPath: /var/lib/postgresql/data
  volumeClaimTemplates:
    - metadata:
        name: data
      spec:
        accessModes:
          - ReadWriteOnce
        storageClassName: longhorn
        resources:
          requests:
            storage: 20Gi
