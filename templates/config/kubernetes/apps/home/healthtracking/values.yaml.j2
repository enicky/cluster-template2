controllers:
  backend:
    strategy: RollingUpdate
    containers:
      app:
        image:
          repository: #{ bootstrap_apps.healthtracking.backend.image.split(':')[0] }#
          tag: #{ bootstrap_apps.healthtracking.backend.image.split(':')[1] }#
        env:
          ASPNETCORE_URLS: http://+:5001
          ASPNETCORE_ENVIRONMENT: Development
          DB_HOST: healthtracking-postgres
          DB_PORT: "5432"
          DB_NAME: #{ bootstrap_apps.healthtracking.database.name }#
          DB_USER: #{ bootstrap_apps.healthtracking.database.user }#
          ConnectionStrings__DefaultConnection: "Host=healthtracking-postgres;Port=5432;Database=#{ bootstrap_apps.healthtracking.database.name }#;Username=#{ bootstrap_apps.healthtracking.database.user }#;Password=$(DB_PASSWORD)"
          Logging__LogLevel__Default: Information
        envFrom:
          - secretRef:
              name: healthtracking-db
        ports:
          - name: http
            containerPort: 5001
            protocol: TCP
        probes:
          liveness:
            enabled: true
            custom: true
            spec:
              httpGet:
                path:  /health/live
                port: 5001
              initialDelaySeconds: 30
              periodSeconds: 10
              timeoutSeconds: 5
              failureThreshold: 3
          readiness:
            enabled: true
            custom: true
            spec:
              httpGet:
                path: /health/ready
                port: 5001
              initialDelaySeconds: 10
              periodSeconds: 5
              timeoutSeconds: 3
              failureThreshold: 3
        securityContext:
          allowPrivilegeEscalation: false
          capabilities: { drop: ["ALL"] }
        resources:
          requests:
            cpu: 100m
            memory: 256Mi
          limits:
            cpu: 500m
            memory: 512Mi

  frontend:
    strategy: RollingUpdate
    containers:
      app:
        image:
          repository: #{ bootstrap_apps.healthtracking.frontend.image.split(':')[0] }#
          tag: #{ bootstrap_apps.healthtracking.frontend.image.split(':')[1] }#
        env:
          NODE_ENV: production
          VITE_API_URL: https://health.#{ cloudflare_domain }#
        ports:
          - name: http
            containerPort: 3000
            protocol: TCP
        probes:
          liveness:
            enabled: true
            custom: true
            spec:
              httpGet:
                path: /
                port: 3000
              initialDelaySeconds: 30
              periodSeconds: 10
              timeoutSeconds: 5
              failureThreshold: 3
          readiness:
            enabled: true
            custom: true
            spec:
              httpGet:
                path: /
                port: 3000
              initialDelaySeconds: 10
              periodSeconds: 5
              timeoutSeconds: 3
              failureThreshold: 3
        securityContext:
          allowPrivilegeEscalation: false
          capabilities: { drop: ["ALL"] }
          readOnlyRootFilesystem: false
        resources:
          requests:
            cpu: 50m
            memory: 128Mi
          limits:
            cpu: 200m
            memory: 256Mi

defaultPodOptions:
  securityContext:
    runAsNonRoot: false
    fsGroup: 999

service:
  backend:
    controller: backend
    ports:
      http:
        port: 5001
        targetPort: 5001

  frontend:
    controller: frontend
    ports:
      http:
        port: 3000
        targetPort: 3000
