---
apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: longhorn
  namespace: longhorn-system
spec:
  parentRefs:
  - name: envoy-external
    namespace: network
  hostnames:
  - longhorn.#{ cloudflare_domain }#
  rules:
  - backendRefs:
    - name: longhorn-frontend
      port: 80
